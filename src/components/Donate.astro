---
// src/components/Donate.astro
---

<section id="donate" class="w-full max-w-4xl mx-auto py-20 px-4">
    <div
        class="bg-(--card-bg) backdrop-blur-xl border border-(--border) rounded-[2.5rem] p-10 md:p-16 text-center shadow-2xl relative overflow-hidden group"
    >
        <!-- Decorative background elements -->
        <div
            class="absolute -top-24 -right-24 w-64 h-64 bg-[#7aa2f7]/10 rounded-full blur-3xl group-hover:bg-[#7aa2f7]/20 transition-colors duration-700"
        >
        </div>
        <div
            class="absolute -bottom-24 -left-24 w-64 h-64 bg-[#bb9af7]/10 rounded-full blur-3xl group-hover:bg-[#bb9af7]/20 transition-colors duration-700"
        >
        </div>

        <h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">
            Support Bubblespace
        </h2>
        <p
            class="text-lg text-(--fg-muted) max-w-2xl mx-auto mb-10 leading-relaxed"
        >
            If you love these icons and want to support the project, consider
            buying me a coffee! Your donations help keep the bubbles floating
            and the pixels perfect.
        </p>

        <div
            class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
            <a
                href="https://ko-fi.com"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-[#7aa2f7] hover:bg-[#7aa2f7]/90 text-white px-8 py-4 rounded-2xl font-semibold transition-all hover:scale-105 flex items-center gap-3 shadow-lg shadow-[#7aa2f7]/20"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path
                        d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"
                    ></path><line x1="6" y1="1" x2="6" y2="4"></line><line
                        x1="10"
                        y1="1"
                        x2="10"
                        y2="4"></line><line x1="14" y1="1" x2="14" y2="4"
                    ></line></svg
                >
                Buy me a Coffee
            </a>
        </div>

        <p class="mt-8 text-sm text-(--fg-muted) italic">
            Every bubble matters. Thank you for being part of the space!
        </p>
    </div>
</section>
